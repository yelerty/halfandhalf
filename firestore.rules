rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 헬퍼 함수: 사용자 인증 여부 확인
    function isAuthenticated() {
      return request.auth != null;
    }

    // 헬퍼 함수: 사용자 본인 확인
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // users 컬렉션: 본인 데이터만 읽기/쓰기 가능
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);

      // 사용자별 채팅 세션 참조
      // 본인만 읽기/삭제 가능, 쓰기는 본인 또는 sessionId가 일치하면 가능
      match /chatSessions/{sessionId} {
        allow read, delete: if isOwner(userId);
        allow write: if isOwner(userId)
          || (isAuthenticated() && 'sessionId' in request.resource.data && request.resource.data.sessionId == sessionId);
      }
    }

    // posts 컬렉션
    match /posts/{postId} {
      // 모든 사용자가 읽기/생성/수정 가능
      allow read, write: if true;
      // 게시글 소유자만 삭제 가능 (userId 필드 없으면 인증된 사용자는 누구나 삭제 가능)
      allow delete: if isAuthenticated() && (!('userId' in resource.data) || request.auth.uid == resource.data.userId);
    }

    // chatSessions 컬렉션
    match /chatSessions/{sessionId} {
      // 참여자만 채팅 세션 읽기 가능
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.get('participants', []);

      // 인증된 사용자는 채팅 세션 생성/수정 가능
      allow create: if isAuthenticated();

      allow update: if isAuthenticated();

      // 참여자만 채팅 세션 삭제 가능
      allow delete: if isAuthenticated()
        && request.auth.uid in resource.data.get('participants', []);

      // 채팅 메시지 컬렉션
      match /messages/{messageId} {
        // 인증된 사용자는 메시지 읽기 가능
        allow read: if isAuthenticated();

        // 인증된 사용자가 자신의 메시지를 작성 가능
        allow create: if isAuthenticated()
          && request.resource.data.senderId == request.auth.uid;

        // 메시지 수정 금지, 삭제는 작성자만 가능
        allow update: if false;
        allow delete: if isAuthenticated()
          && request.resource.data.senderId == request.auth.uid;
      }
    }

    // 기타 모든 문서 접근 거부
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
