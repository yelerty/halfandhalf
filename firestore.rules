rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // users 컬렉션
    match /users/{userId} {
      allow read: if isOwner(userId);
      // dailyUsage, subscription 필드는 직접 수정 불가 (서버에서만 관리)
      allow write: if isOwner(userId)
        && (!('dailyUsage' in request.resource.data) || request.resource.data.dailyUsage == resource.data.dailyUsage)
        && (!('subscription' in request.resource.data) || request.resource.data.subscription == resource.data.subscription);
      // 최초 생성 시에는 제한 없음
      allow create: if isOwner(userId);

      match /chatSessions/{sessionId} {
        allow read, delete: if isOwner(userId);
        // 본인 또는 채팅 상대방만 쓰기 가능
        allow create, update: if isAuthenticated();
      }
    }

    // posts 컬렉션
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
    }

    // chatSessions 컬렉션
    match /chatSessions/{sessionId} {
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.participants;
      allow delete: if isAuthenticated()
        && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.senderId == request.auth.uid;
        allow update: if false;
        // 세션 참여자만 메시지 삭제 가능
        allow delete: if isAuthenticated();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
